GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
VECTOR_DB_PATH=./data/vector_store
KB_DATA_DIR=./data/kb
KNOWLEDGE_COLLECTION_NAME=truthguard_knowledge
RAG_TOP_K=5
LIVE_WEB_TOP_K=4
EMBEDDING_DIMENSIONS=768
ENABLE_LIVE_WEB_RETRIEVAL=true
# Optional comma-separated domains to prioritize during live retrieval.
TRUSTED_SOURCE_ALLOWLIST=whitehouse.gov,reuters.com,apnews.com,bbc.com,npr.org,cdc.gov,who.int,wikipedia.org
